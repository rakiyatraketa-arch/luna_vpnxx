# Apex VPN backend (apex-backend.js) — переменные окружения.
# Скопируй в .env (он в .gitignore) и подставь реальные значения НА СЕРВЕРЕ.

# Секретный ключ AyfoPay (НИКОГДА не коммить и не клади в приложение!).
# ВНИМАНИЕ: ключ, присланный в чат, считается скомпрометированным —
# перевыпусти его в поддержке AyfoPay и вставь новый сюда.
AYFOPAY_API_KEY=put-your-secret-key-here

# Порт/хост бэкенда (за HTTPS-прокси, напр. nginx/caddy).
PORT=8090
HOST=0.0.0.0

# Каталог для JSON-хранилища профилей/заказов.
DATA_DIR=./apex-data

# Твой публичный https-URL (для логов и webhook). Пример:
# PUBLIC_BASE=https://api.apexvpn.tld
PUBLIC_BASE=
