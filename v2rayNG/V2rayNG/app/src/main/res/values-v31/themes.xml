<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ (API 31): явно задаём иконку и фон системного Splash Screen,
         чтобы не показывался дефолтный значок пакета com.v2ray.ang -->
    <style name="AppThemeDayNight.NoActionBar" parent="AppThemeDayNight">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowSplashScreenBackground">#FFFFFF</item>
        <item name="android:windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_foreground</item>
        <item name="android:windowSplashScreenIconBackgroundColor">#FFFFFF</item>
    </style>
</resources>
