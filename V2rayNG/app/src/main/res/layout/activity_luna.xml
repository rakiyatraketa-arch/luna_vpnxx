<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:a="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    a:layout_width="match_parent"
    a:layout_height="match_parent"
    a:background="@color/luna_bg"
    a:fitsSystemWindows="true">

    <!-- Top bar: menu + server name + settings -->
    <ImageButton
        a:id="@+id/luna_btn_menu"
        a:layout_width="48dp"
        a:layout_height="48dp"
        a:layout_marginStart="12dp"
        a:layout_marginTop="12dp"
        a:background="?android:attr/selectableItemBackgroundBorderless"
        a:contentDescription="@string/luna_menu"
        a:src="@drawable/luna_ic_menu"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        a:id="@+id/luna_server_name"
        a:layout_width="0dp"
        a:layout_height="wrap_content"
        a:layout_marginStart="8dp"
        a:layout_marginEnd="8dp"
        a:ellipsize="end"
        a:gravity="center"
        a:maxLines="1"
        a:text="@string/luna_no_server"
        a:textColor="@color/luna_text_primary"
        a:textSize="16sp"
        a:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/luna_btn_menu"
        app:layout_constraintEnd_toStartOf="@id/luna_btn_servers"
        app:layout_constraintStart_toEndOf="@id/luna_btn_menu"
        app:layout_constraintTop_toTopOf="@id/luna_btn_menu" />

    <ImageButton
        a:id="@+id/luna_btn_servers"
        a:layout_width="48dp"
        a:layout_height="48dp"
        a:layout_marginTop="12dp"
        a:layout_marginEnd="12dp"
        a:background="?android:attr/selectableItemBackgroundBorderless"
        a:contentDescription="@string/luna_servers"
        a:src="@drawable/ic_settings_24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/luna_text_primary" />

    <!-- Moon -->
    <com.v2ray.ang.ui.luna.MoonView
        a:id="@+id/luna_moon"
        a:layout_width="280dp"
        a:layout_height="280dp"
        a:layout_marginTop="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/luna_btn_menu" />

    <!-- Status text -->
    <TextView
        a:id="@+id/luna_status_text"
        a:layout_width="wrap_content"
        a:layout_height="wrap_content"
        a:layout_marginTop="8dp"
        a:letterSpacing="0.1"
        a:text="@string/luna_status_unprotected"
        a:textColor="@color/luna_status_unprotected"
        a:textSize="22sp"
        a:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/luna_moon" />

    <!-- IP row -->
    <LinearLayout
        a:id="@+id/luna_ip_row"
        a:layout_width="wrap_content"
        a:layout_height="wrap_content"
        a:layout_marginTop="6dp"
        a:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/luna_status_text">

        <TextView
            a:id="@+id/luna_ip_label"
            a:layout_width="wrap_content"
            a:layout_height="wrap_content"
            a:text="@string/luna_ip_label"
            a:textColor="@color/luna_text_secondary"
            a:textSize="13sp" />

        <TextView
            a:id="@+id/luna_ip_value"
            a:layout_width="wrap_content"
            a:layout_height="wrap_content"
            a:layout_marginStart="6dp"
            a:fontFamily="monospace"
            a:text="—"
            a:textColor="@color/luna_text_primary"
            a:textSize="13sp" />
    </LinearLayout>

    <!-- Big connect button -->
    <FrameLayout
        a:id="@+id/luna_btn_wrap"
        a:layout_width="140dp"
        a:layout_height="140dp"
        a:layout_marginTop="28dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/luna_ip_row">

        <FrameLayout
            a:id="@+id/luna_btn"
            a:layout_width="120dp"
            a:layout_height="120dp"
            a:layout_gravity="center"
            a:background="@drawable/luna_btn_connect_selector"
            a:clickable="true"
            a:focusable="true"
            a:foreground="?android:attr/selectableItemBackgroundBorderless">

            <ImageView
                a:layout_width="56dp"
                a:layout_height="56dp"
                a:layout_gravity="center"
                a:contentDescription="@string/luna_connect"
                a:src="@drawable/luna_ic_power"
                app:tint="@color/luna_text_primary" />
        </FrameLayout>
    </FrameLayout>

    <!-- Stats card -->
    <androidx.constraintlayout.widget.ConstraintLayout
        a:id="@+id/luna_stats_card"
        a:layout_width="0dp"
        a:layout_height="wrap_content"
        a:layout_marginStart="20dp"
        a:layout_marginEnd="20dp"
        a:layout_marginBottom="32dp"
        a:background="@drawable/luna_card_bg"
        a:padding="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Row 1: down + up -->
        <LinearLayout
            a:id="@+id/luna_row_speed"
            a:layout_width="0dp"
            a:layout_height="wrap_content"
            a:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Download -->
            <LinearLayout
                a:layout_width="0dp"
                a:layout_height="wrap_content"
                a:layout_weight="1"
                a:gravity="center_vertical"
                a:orientation="horizontal">

                <ImageView
                    a:layout_width="20dp"
                    a:layout_height="20dp"
                    a:src="@drawable/luna_ic_download" />

                <LinearLayout
                    a:layout_width="wrap_content"
                    a:layout_height="wrap_content"
                    a:layout_marginStart="8dp"
                    a:orientation="vertical">

                    <TextView
                        a:layout_width="wrap_content"
                        a:layout_height="wrap_content"
                        a:text="@string/luna_download"
                        a:textColor="@color/luna_text_secondary"
                        a:textSize="11sp" />

                    <TextView
                        a:id="@+id/luna_tv_download"
                        a:layout_width="wrap_content"
                        a:layout_height="wrap_content"
                        a:fontFamily="monospace"
                        a:text="0 KB/s"
                        a:textColor="@color/luna_text_primary"
                        a:textSize="15sp"
                        a:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Upload -->
            <LinearLayout
                a:layout_width="0dp"
                a:layout_height="wrap_content"
                a:layout_weight="1"
                a:gravity="center_vertical"
                a:orientation="horizontal">

                <ImageView
                    a:layout_width="20dp"
                    a:layout_height="20dp"
                    a:src="@drawable/luna_ic_upload" />

                <LinearLayout
                    a:layout_width="wrap_content"
                    a:layout_height="wrap_content"
                    a:layout_marginStart="8dp"
                    a:orientation="vertical">

                    <TextView
                        a:layout_width="wrap_content"
                        a:layout_height="wrap_content"
                        a:text="@string/luna_upload"
                        a:textColor="@color/luna_text_secondary"
                        a:textSize="11sp" />

                    <TextView
                        a:id="@+id/luna_tv_upload"
                        a:layout_width="wrap_content"
                        a:layout_height="wrap_content"
                        a:fontFamily="monospace"
                        a:text="0 KB/s"
                        a:textColor="@color/luna_text_primary"
                        a:textSize="15sp"
                        a:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <View
            a:id="@+id/luna_divider"
            a:layout_width="0dp"
            a:layout_height="1dp"
            a:layout_marginTop="14dp"
            a:background="@color/luna_card_stroke"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/luna_row_speed" />

        <!-- Row 2: time + ping -->
        <LinearLayout
            a:id="@+id/luna_row_meta"
            a:layout_width="0dp"
            a:layout_height="wrap_content"
            a:layout_marginTop="14dp"
            a:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/luna_divider">

            <LinearLayout
                a:layout_width="0dp"
                a:layout_height="wrap_content"
                a:layout_weight="1"
                a:gravity="center_vertical"
                a:orientation="horizontal">

                <ImageView
                    a:layout_width="18dp"
                    a:layout_height="18dp"
                    a:src="@drawable/luna_ic_time" />

                <LinearLayout
                    a:layout_width="wrap_content"
                    a:layout_height="wrap_content"
                    a:layout_marginStart="8dp"
                    a:orientation="vertical">

                    <TextView
                        a:layout_width="wrap_content"
                        a:layout_height="wrap_content"
                        a:text="@string/luna_session"
                        a:textColor="@color/luna_text_secondary"
                        a:textSize="11sp" />

                    <TextView
                        a:id="@+id/luna_tv_time"
                        a:layout_width="wrap_content"
                        a:layout_height="wrap_content"
                        a:fontFamily="monospace"
                        a:text="00:00:00"
                        a:textColor="@color/luna_text_primary"
                        a:textSize="15sp"
                        a:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                a:layout_width="0dp"
                a:layout_height="wrap_content"
                a:layout_weight="1"
                a:gravity="center_vertical"
                a:orientation="horizontal">

                <ImageView
                    a:layout_width="18dp"
                    a:layout_height="18dp"
                    a:src="@drawable/luna_ic_ping" />

                <LinearLayout
                    a:layout_width="wrap_content"
                    a:layout_height="wrap_content"
                    a:layout_marginStart="8dp"
                    a:orientation="vertical">

                    <TextView
                        a:layout_width="wrap_content"
                        a:layout_height="wrap_content"
                        a:text="@string/luna_ping"
                        a:textColor="@color/luna_text_secondary"
                        a:textSize="11sp" />

                    <TextView
                        a:id="@+id/luna_tv_ping"
                        a:layout_width="wrap_content"
                        a:layout_height="wrap_content"
                        a:fontFamily="monospace"
                        a:text="— ms"
                        a:textColor="@color/luna_text_primary"
                        a:textSize="15sp"
                        a:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
